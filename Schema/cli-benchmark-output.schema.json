{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/ratelimiter/cli-benchmark-output.schema.json",
  "title": "CLI Benchmark Output",
  "description": "Schema for JSON printed by: ratelimit benchmark ...",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "algorithm",
      "allowed",
      "denied",
      "requests",
      "threads",
      "keys",
      "cost",
      "elapsed_seconds",
      "throughput_per_second",
      "approximate_memory_bytes"
    ],
    "properties": {
      "algorithm": {
        "type": "string",
        "enum": ["token", "token-bucket", "fixed", "fixed-window", "sliding", "sliding-counter", "sliding-window-counter", "leaky", "leaky-bucket"]
      },
      "allowed": { "type": "integer", "minimum": 0 },
      "denied": { "type": "integer", "minimum": 0 },
      "requests": { "type": "integer", "minimum": 0 },
      "threads": { "type": "integer", "minimum": 1 },
      "keys": { "type": "integer", "minimum": 1 },
      "cost": { "type": "number", "exclusiveMinimum": 0 },
      "elapsed_seconds": { "type": "number", "minimum": 0 },
      "throughput_per_second": { "type": "number", "minimum": 0 },
      "approximate_memory_bytes": { "type": "integer", "minimum": 0 }
    },
    "additionalProperties": false
  }
}
